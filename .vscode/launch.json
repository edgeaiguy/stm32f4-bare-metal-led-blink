{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug (OpenOCD)",
            "type": "cortex-debug",
            "request": "launch",
            "servertype": "openocd",
            "cwd": "${workspaceFolder}",
            "executable": "${workspaceFolder}/Debug/helloworld.elf",
            "gdbPath": "gdb-multiarch",
            "objdumpPath": "objdump",
            "svdFile": "/opt/st/stm32cubeide_2.0.0/plugins/com.st.stm32cube.ide.mcu.productdb.debug_2.2.300.202510101821/resources/cmsis/STMicroelectronics_CMSIS_SVD/STM32F407.svd",
            "device": "STM32F407VG",
            "configFiles": [
                "interface/stlink.cfg",
                "target/stm32f4x.cfg"
            ],
            "openOCDLaunchCommands": [
                "reset_config srst_only"
            ],
            "runToEntryPoint": "main",
            //"breakAfterReset": true,
            "showDevDebugOutput": "none",
            "preLaunchTask": "Build Debug"
        },
        {
            "name": "Attach (OpenOCD)",
            "type": "cortex-debug",
            "request": "attach",
            "servertype": "openocd",
            "cwd": "${workspaceFolder}",
            "executable": "${workspaceFolder}/Debug/helloworld.elf",
            "gdbPath": "gdb-multiarch",
            "objdumpPath": "objdump",
            "svdFile": "/opt/st/stm32cubeide_2.0.0/plugins/com.st.stm32cube.ide.mcu.productdb.debug_2.2.300.202510101821/resources/cmsis/STMicroelectronics_CMSIS_SVD/STM32F407.svd",
            "device": "STM32F407VG",
            "configFiles": [
                "interface/stlink.cfg",
                "target/stm32f4x.cfg"
            ],
            "showDevDebugOutput": "none"
        }
    ]
}
